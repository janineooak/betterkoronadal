# City Government of Koronadal — Website Configuration
# Copy this file to .env.local and update with the correct values.

# Government Information
VITE_GOVERNMENT_NAME="City of Koronadal"
VITE_GOVERNMENT_TYPE="City"
VITE_REGION="Region XII (SOCCSKSARGEN)"
VITE_PROVINCE="South Cotabato"

# Website Information
VITE_WEBSITE_URL="https://koronadal.gov.ph"
VITE_CONTACT_EMAIL="info.koronadalcity@gmail.com"
VITE_CONTACT_PHONE="(083) 228-6095"

# Social Media (Optional)
VITE_FACEBOOK_URL="https://facebook.com/CityGovernmentofKoronadal"
VITE_TWITTER_URL=""
VITE_INSTAGRAM_URL=""
VITE_YOUTUBE_URL=""

# SEO
VITE_SITE_DESCRIPTION="Official website of the City Government of Koronadal, capital of South Cotabato and regional center of SOCCSKSARGEN."
VITE_SITE_KEYWORDS="Koronadal, City of Koronadal, Marbel, South Cotabato, SOCCSKSARGEN, city government, public services, permits, hotlines"
VITE_OG_IMAGE_URL="https://koronadal.gov.ph/og-image.jpg"
VITE_TWITTER_HANDLE=""

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=""
VITE_FACEBOOK_PIXEL_ID=""
