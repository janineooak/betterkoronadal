# betterKoronadal — Website Configuration
#
# IMPORTANT: This is "betterKoronadal" — an INDEPENDENT, COMMUNITY-BUILT portal
# for the City of Koronadal. It is NOT the official city website and is NOT
# affiliated with, operated by, or endorsed by the City Government of Koronadal.
# The official city website is https://koronadal.gov.ph.
#
# The city's public contact details below are shown only as a convenience/
# reference for residents — they are the City Government's, not this project's.
#
# Copy this file to .env.local (local dev) or set these in your host
# (e.g. Railway → Variables) and update with your own values.

# Branding
# Shown in the navbar/hero. Keep the "betterKoronadal" prefix so visitors
# understand this is a community version, not the official site.
VITE_GOVERNMENT_NAME="betterKoronadal"
VITE_GOVERNMENT_TYPE="City"
VITE_REGION="Region XII (SOCCSKSARGEN)"
VITE_PROVINCE="South Cotabato"

# Website Information
# This is the URL of THIS community portal — NOT koronadal.gov.ph.
VITE_WEBSITE_URL="https://betterkoronadal.org"
# The City Government's public contact details (reference only).
VITE_CONTACT_EMAIL="info.koronadalcity@gmail.com"
VITE_CONTACT_PHONE="(083) 228-6095"

# Social Media (Optional)
# The City Government's official Facebook page (reference only).
VITE_FACEBOOK_URL="https://facebook.com/CityGovernmentofKoronadal"
VITE_TWITTER_URL=""
VITE_INSTAGRAM_URL=""
VITE_YOUTUBE_URL=""

# SEO
VITE_SITE_DESCRIPTION="betterKoronadal is an independent, community-built portal that makes information and services for the City of Koronadal easier to find. It is not the official city website."
VITE_SITE_KEYWORDS="betterKoronadal, Koronadal, Marbel, South Cotabato, SOCCSKSARGEN, community portal, unofficial, city services, hotlines"
VITE_OG_IMAGE_URL="https://betterkoronadal.org/og-image.jpg"
VITE_TWITTER_HANDLE=""

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=""
VITE_FACEBOOK_PIXEL_ID=""
