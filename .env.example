# Bantay Opisyal admin backend (optional). With NONE of these set, the site
# runs exactly as a static site on its code-curated data. Set them (in Vercel
# project env vars) to enable citizen submissions + the admin dashboard.

# Postgres connection string (e.g. from Railway). Server-side only.
DATABASE_URL=postgresql://user:password@host:port/dbname

# Set to "disable" only for a local DB without SSL. Leave unset for Railway.
# PGSSL=disable

# Secret used to sign admin session tokens. Use a long random string.
ADMIN_SECRET=change-me-to-a-long-random-string

# Admin accounts: "username:password" pairs, comma-separated. Two or more
# admins enables enforced two-person review for court cases / concerns.
ADMIN_USERS=alice:strong-password-1,bob:strong-password-2
